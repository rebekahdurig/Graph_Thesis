# ─────────────────────────────────────────────────────────────────────────────
# AUTOMATON RULES  ← YOUR MAIN CUSTOMIZATION POINT
# ─────────────────────────────────────────────────────────────────────────────

def compute_next_state(current_state: int, live_neighbor_count: int, total_neighbor_count: int, mod: int = 2) -> int:
    """
    Determine the next state (0 or 1) for a node.

    This is where YOU define the rules of your automaton.
    The function is called once per node per time step.

    Parameters
    ----------
    current_state : int
        The node's current state — 0 (off) or 1 (on).
    live_neighbor_count : int
        How many of this node's direct neighbors are currently ON (state == 1).
    total_neighbor_count : int
        The total number of neighbors this node has (its degree).
        Useful for ratio-based or degree-sensitive rules.

    Returns
    -------
    int
        The node's next state: 0 or 1.
    """

    # ── Game of Light (GOL) Rules ──────────────
    if current_state == 1:
        #Calculates the modulo of the non-live neighbors
        return (total_neighbor_count-live_neighbor_count) % mod
    else:
        return live_neighbor_count % mod
    # ── END GOL Rules ───────────────────────────────────────────────────


