class MainWindow(QMainWindow):

    def __init__(self):
        super().__init__()
        self.model = GraphModel(mod=2)

        self.setWindowTitle("Graph Automaton")
        self.setStyleSheet(f"background-color: {PANEL_COLOR}; color: {TEXT_COLOR};")

        self._build_ui()
        self._update_stats()

    # ── UI construction ───────────────────────────────────────────────────

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setSpacing(8)
        root.setContentsMargins(10, 10, 10, 10)

        # ── Canvas ──
        self.canvas = GraphCanvas(self.model, on_change=self._update_stats)
        root.addWidget(self.canvas)

        # ── Stats bar ──
        stats_row = QHBoxLayout()
        self.lbl_nodes = self._stat_label("Nodes: 0")
        self.lbl_edges = self._stat_label("Edges: 0")
        self.lbl_live  = self._stat_label("Live: 0")
        self.lbl_step  = self._stat_label("Step: 0")
        for lbl in (self.lbl_nodes, self.lbl_edges, self.lbl_live, self.lbl_step):
            stats_row.addWidget(lbl)
        stats_row.addStretch()
        root.addLayout(stats_row)

        # ── Buttons ──
        btn_row = QHBoxLayout()

        btn_step   = self._button("⏭  Step  [Space]", self._advance_step)
        btn_prune  = self._button("✂  Remove Isolated", self._remove_isolated)
        btn_matrix = self._button("🔢  Print Matrix", self._print_matrix)
        btn_clear  = self._button("🗑  Clear All", self._clear_all)
        btn_calc = self._button("🖩 Calculate GOL Structure", self._calculate_gol)

        for btn in (btn_step, btn_prune, btn_matrix, btn_clear, btn_calc):
            btn_row.addWidget(btn)

        root.addLayout(btn_row)

        # ── Instructions ──
        hint = QLabel(
            "Left-click empty space → add node  |  "
            "Left-click node → select  |  "
            "Left-click second node → add edge  |  "
            "Right-click node → toggle state  |  "
            "Space → advance time"
        )
        hint.setStyleSheet("color: #888; font-size: 11px;")
        hint.setAlignment(Qt.AlignmentFlag.AlignCenter)
        root.addWidget(hint)

    def _stat_label(self, text: str) -> QLabel:
        lbl = QLabel(text)
        lbl.setStyleSheet(
            f"background: #0f3460; color: {TEXT_COLOR}; "
            "padding: 4px 12px; border-radius: 4px; font-family: Courier;"
        )
        return lbl

    def _button(self, text: str, slot) -> QPushButton:
        btn = QPushButton(text)
        btn.clicked.connect(slot)
        btn.setStyleSheet(
            "QPushButton {"
            f"  background: #0f3460; color: {TEXT_COLOR};"
            "  padding: 6px 14px; border-radius: 4px;"
            "  font-size: 12px;"
            "}"
            "QPushButton:hover { background: #1a4a80; }"
        )
        return btn

    # ── Keyboard ──────────────────────────────────────────────────────────

    def keyPressEvent(self, event):
        if event.key() == Qt.Key.Key_Space:
            self._advance_step()
        else:
            super().keyPressEvent(event)

    # ── Actions ───────────────────────────────────────────────────────────

    def _advance_step(self):
        self.model.step()
        self.canvas.time_step += 1
        self.canvas.redraw()
        self._update_stats()

    def _remove_isolated(self):
        n = self.model.remove_isolated_nodes()
        self.canvas.redraw()
        self._update_stats()
        self.statusBar().showMessage(f"Removed {n} isolated node(s).", 3000)

    def _print_matrix(self):
        """
        Prints the adjacency matrix and state vector to stdout.
        You could extend this to display in a dialog, export to CSV, etc.
        """
        matrix = self.model.harmonic_matrix()
        states = self.model.state_vector()
        print("\n── Adjacency Matrix ──")
        print(matrix)
        print("\n── State Vector ──")
        print(states)
        self.statusBar().showMessage("Matrix printed to console.", 3000)

    def _clear_all(self):
        self.model.clear()
        self.canvas.time_step = 0
        self.canvas.selected_node = None
        self.canvas.redraw()
        self._update_stats()

    def _update_stats(self):
        self.lbl_nodes.setText(f"Nodes: {self.model.node_count}")
        self.lbl_edges.setText(f"Edges: {self.model.edge_count}")
        self.lbl_live.setText(f"Live: {self.model.live_count}")
        self.lbl_step.setText(f"Step: {self.canvas.time_step}")

    def _calculate_gol(self):
        self.model.calculate_gol()
        return None


