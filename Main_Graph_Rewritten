class GraphModel:
    """
    Wraps a NetworkX graph and exposes the operations the UI needs.
    All graph-theory logic lives here; the view never touches nx directly.
    """

    def __init__(self, mod: int):
        self.G = nx.Graph()
        self._next_id = 0
        self.mod = mod
        self.GF = galois.GF(mod)

    # ── Node operations ───────────────────────────────────────────────────

    def add_node(self, x: float, y: float) -> int:
        nid = self._next_id
        state = initial_state_for_new_node(self.G, nid)
        self.G.add_node(nid, x=x, y=y, state=state)
        self._next_id += 1
        return nid

    def remove_node(self, nid: int):
        if nid in self.G:
            self.G.remove_node(nid)

    def toggle_node_state(self, nid: int):
        """Manually flip a node's state (useful for setup / debugging)."""
        if nid in self.G:
            self.G.nodes[nid]['state'] ^= 1

    def remove_isolated_nodes(self):
        """Delete all nodes that have no edges."""
        isolated = list(nx.isolates(self.G))
        self.G.remove_nodes_from(isolated)
        return len(isolated)

    # ── Edge operations ───────────────────────────────────────────────────

    def add_edge(self, u: int, v: int):
        if u != v and not self.G.has_edge(u, v):
            self.G.add_edge(u, v)
            return True
        return False

    def remove_edge(self, u: int, v: int):
        if self.G.has_edge(u, v):
            self.G.remove_edge(u, v)

    # ── Automaton step ────────────────────────────────────────────────────

    def step(self):
        """
        Advance the automaton by one time step.
        All nodes are updated simultaneously (synchronous update).

        If you want ASYNCHRONOUS update (nodes update one at a time in
        some order), replace this method with a loop that updates each
        node and immediately writes the result back to self.G.
        """
        new_states = {}
        for nid in self.G.nodes:
            neighbors = list(self.G.neighbors(nid))
            live = sum(self.G.nodes[n]['state'] for n in neighbors)
            total = len(neighbors)
            new_states[nid] = compute_next_state(
                self.G.nodes[nid]['state'], live, total, self.mod
            )
        nx.set_node_attributes(self.G, new_states, 'state')

    # ── Matrix / stats ────────────────────────────────────────────────────

    def adjacency_matrix(self) -> np.ndarray:
        """Returns the adjacency matrix as a numpy array."""
        return self.GF(nx.to_numpy_array(self.G, dtype = int))
    
    def harmonic_matrix(self) -> np.ndarray:
        """Defines a harmonic operator as in section 3 of paper"""
        A = self.adjacency_matrix()
        degrees = np.array([d % self.mod for _,d in self.G.degree()])
        D = self.GF(np.diag(degrees))
        return (A + D)

    def state_vector(self) -> np.ndarray:
        """Returns a 1-D array of every node's current state."""
        return np.array([self.G.nodes[n]['state'] for n in self.G.nodes])

    @property
    def node_count(self) -> int:
        return self.G.number_of_nodes()

    @property
    def edge_count(self) -> int:
        return self.G.number_of_edges()
    
    @property
    def edges(self) -> list:
        return self.G.edges

    @property
    def live_count(self) -> int:
        return sum(d['state'] for _, d in self.G.nodes(data=True))

    def node_at(self, x: float, y: float, radius: float = NODE_RADIUS) -> int | None:
        """Return the id of the first node within `radius` of (x, y), or None."""
        for nid, data in self.G.nodes(data=True):
            dx = data['x'] - x
            dy = data['y'] - y
            if (dx * dx + dy * dy) ** 0.5 <= radius:
                return nid
        return None

    def clear(self):
        self.G.clear()
        self._next_id = 0

    def mobius(self, m): #Checked up to m=60 and producing correct results
        if m == 1:
            return 1
        parity=0
        n = m
        # print("max loop con: ", np.sqrt(m)+1)
        for i in np.r_[2, 3:int(np.ceil(np.sqrt(m)+1)):2]:
            # print(i)
            if n%i == 0:
                parity += 1
                # print('parity increased')
                n = n//i
                if n%i == 0:
                    # print('square found')
                    return 0
        if n > 1: #catches when n is prime, or case where a prime factor is larger than sqrt (generally when numbers/number of factors are small, like 2*7 = 14, 2 will be caught in loop, but 7 won't)
            # print("n not fully reduced by loop")
            parity += 1  
        # print("parity: ", parity)
        return (-1)**parity

    def calculate_gol(self):
        self.remove_isolated_nodes()
        states = self.mod**(self.node_count) #define n as number of nodes in graph
        #Create a dictionary of keys n and a^n where A is the adjacency matrix. N should run between 1 and when dim Ker(a^n) == dim Ker(a^(n+1))
        counter = 1
        matrix_powers = {0:np.eye(self.node_count)}
        matrix_ker_dims = {0:0}
        while True:
            matrix_power_calc = np.linalg.matrix_power(self.harmonic_matrix(), counter)
            matrix_powers[counter] = matrix_power_calc
            matrix_ker_dim_calc = self.node_count - np.linalg.matrix_rank(matrix_power_calc)
            matrix_ker_dims[counter] = matrix_ker_dim_calc
            if matrix_ker_dims[counter] <= matrix_ker_dims[counter-1]:
                break
            else:
                counter+=1

        tree_dict = self.calculate_trees(matrix_ker_dims)
        print("Tree Dictionary:")
        print(tree_dict)
        #Update states by dividing the number of states by product of 2^i^bi (this is the maximum number of loop nodes we need to consider)
        tree_size = math.prod(2**(tree_size * mult) for tree_size, mult in tree_dict.items())
        states = states / tree_size
        loops_dict = self.calculate_loops(states, self.harmonic_matrix(), matrix_powers)
        print("Loop Dictionary: ")
        print(loops_dict)
        #Format output and return (print statement? something else?)
        return None

    def calculate_trees(self, matrix_ker_dict):
        dict_size = len(matrix_ker_dict)
        tree_dict = {}

        for i in range(1, dict_size-1):
            test_calc = 2*matrix_ker_dict[i]-matrix_ker_dict[i-1]-matrix_ker_dict[i+1]
            if test_calc > 0:
                tree_dict[i] = test_calc
        return tree_dict

    def calculate_loops(self, states: int, matrix, matrix_dict):
        loop_dict = {}
        p = 1
        while states > 0:
            if p > states:
                print("Calculate Loops is broken")
                return None
            #write while loop for all divisors of p (i)
            # temp_sum_array = []
            sum = 0
            for i in range(1,p+1):
                if p%i != 0:
                    continue
                if self.mobius((p//i)) == 0:
                    continue
                if i not in matrix_dict:
                    matrix_dict[i] = np.linalg.matrix_power(matrix, i)
                
                #Now calculate dimension of eigenspace for lambda = 1
                #Recalculate this for other mods except Z2!!!
                eigenspace_dim = matrix_dict[i].shape[0] - np.linalg.matrix_rank(matrix_dict[i] - self.GF(galois.Array.Identity(matrix_dict[i].shape[0]))) #eigenspace measures kernel size
                sum += self.mobius(p//i)*(2**(eigenspace_dim))
            if sum > 0:
                states = states - sum
                loop_dict[p] = int(sum/p)
            p += 1
        return loop_dict



