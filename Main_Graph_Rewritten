class GraphCanvas(QGraphicsView):
    """
    Handles all mouse interaction and drawing.
    Communicates back to the main window via callbacks.
    """

    def __init__(self, model: GraphModel, on_change):
        super().__init__()
        self.model = model
        self.on_change = on_change          # called whenever the graph changes
        self.selected_node = None           # first node in a pending edge

        self.time_step = 0
        self._scene = QGraphicsScene(self)
        self.setScene(self._scene)
        self.setRenderHint(QPainter.RenderHint.Antialiasing)
        self.setBackgroundBrush(QBrush(QColor(BACKGROUND_COLOR)))
        self.setMinimumSize(700, 500)
        self.setHorizontalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)
        self.setVerticalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)

    # ── Mouse events ──────────────────────────────────────────────────────

    def mousePressEvent(self, event):
        pos = self.mapToScene(event.position().toPoint())
        x, y = pos.x(), pos.y()

        if event.button() == Qt.MouseButton.LeftButton:
            hit = self.model.node_at(x, y)

            if hit is None:
                # Empty space → create a new node
                self.model.add_node(x, y)
                self.selected_node = None
                self.redraw()
                self.on_change()

            else:
                # Clicked an existing node
                if self.selected_node is None:
                    # First click — select it
                    self.selected_node = hit
                    self.redraw()
                elif self.selected_node == hit:
                    # Clicked the same node again — deselect
                    self.selected_node = None
                    self.redraw()
                else:
                    # Second click on a different node
                    #if edge already exists, delete it
                    if (self.selected_node, hit) in (self.model.edges):
                        self.model.remove_edge(self.selected_node, hit)
                        #reset timer if edges change
                        self.time_step = 0
                        self.selected_node = None
                        self.redraw()
                        self.on_change()
                    #if edge doesn't exist, create it
                    else:
                        self.model.add_edge(self.selected_node, hit)
                        #reset timer if edges change
                        self.time_step = 0
                        self.selected_node = None
                        self.redraw()
                        self.on_change()
                        

        elif event.button() == Qt.MouseButton.RightButton:
            # Right-click a node to toggle its on/off state manually
            hit = self.model.node_at(x, y)
            if hit is not None:
                self.model.toggle_node_state(hit)
                #reset timer if states change
                self.time_step = 0
                self.redraw()
                self.on_change()


    # ── Drawing ───────────────────────────────────────────────────────────

    def redraw(self):
        """Clear and repaint everything from the model."""
        self._scene.clear()

        G = self.model.G

        # Draw edges first (so they appear under nodes)
        edge_pen = QPen(EDGE_COLOR, 2)
        for u, v in G.edges():
            x1, y1 = G.nodes[u]['x'], G.nodes[u]['y']
            x2, y2 = G.nodes[v]['x'], G.nodes[v]['y']
            self._scene.addLine(x1, y1, x2, y2, edge_pen)

        # Draw nodes
        for nid, data in G.nodes(data=True):
            cx, cy = data['x'], data['y']
            r = NODE_RADIUS
            state = data['state']

            fill = NODE_COLOR_ON if state == 1 else NODE_COLOR_OFF
            border_color = SELECTED_COLOR if nid == self.selected_node else NODE_BORDER
            pen = QPen(border_color, 2.5)
            brush = QBrush(fill)

            ellipse = self._scene.addEllipse(
                cx - r, cy - r, r * 2, r * 2, pen, brush
            )

            # Draw node id label
            label = self._scene.addText(str(nid))
            label.setDefaultTextColor(QColor("#ffffff"))
            label.setFont(QFont("Courier", 8))
            label.setPos(cx - r * 0.6, cy - r * 0.7)


